          <mxGeometry x="200" y="610" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- 一致なし -->
        <mxCell id="match_no" value="一致なし&#xa;→ ドラフトに含める" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#000000;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="610" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- S5 フィルタ結果記録 -->
        <mxCell id="s5" value="S５ フィルタ結果記録&#xa;&#xa;除外された各項目を構造化データとして記録:&#xa;・除外種別:「発達マイルストーン」&#xa;・除外内容: 除外された文の本文&#xa;・除外理由: キーワード名を含む説明文" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#000000;strokeWidth=2;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="260" y="710" width="300" height="100" as="geometry"/>
        </mxCell>

        <!-- S6 ドラフト生成 -->
