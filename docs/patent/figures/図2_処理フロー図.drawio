        <mxCell id="s4title" value="S４ 発達マイルストーンフィルタリング【本発明の中核】" style="text;html=1;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="210" y="410" width="400" height="25" as="geometry"/>
        </mxCell>

        <!-- 第一段階 -->
        <mxCell id="stage1" value="第一段階: 既定発達マイルストーンキーワード群との照合&#xa;&#xa;「初めて歩」「はじめて歩」「初めて立」「はじめて立」&#xa;「初めてのことば」「はじめてのことば」...（全18語）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#000000;fontSize=10;align=center;" vertex="1" parent="1">
