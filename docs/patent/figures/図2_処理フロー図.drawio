        <mxCell id="stage2" value="第二段階: 対象者別カスタムフィルタ規則&#xa;（配慮事項データベース「発達マイルストーンフィルタ」カテゴリから取得）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#000000;fontSize=10;align=center;" vertex="1" parent="1">
