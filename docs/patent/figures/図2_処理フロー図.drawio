        </mxCell>

        <!-- S4 フィルタリング（強調枠） -->
        <mxCell id="s4frame" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbe6;strokeColor=#000000;strokeWidth=3;dashed=0;" vertex="1" parent="1">
