        </mxCell>
        <mxCell id="legend_title" value="【凡例】" style="text;html=1;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="515" width="60" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="legend1" value="★ = 本発明の中核をなすデータ要素" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="535" width="300" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="legend2" value="→ = 外部キー参照（リレーション方向）" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="553" width="300" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="legend3" value="日本語名 (英字名) = テーブル名／フィールド名の表記形式" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="571" width="320" height="18" as="geometry"/>
