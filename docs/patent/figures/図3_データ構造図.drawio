              <mxPoint x="710" y="500"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 対象者 → 連絡帳（参照） -->
        <mxCell id="r5" value="1 : N" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#000000;fontSize=10;fontStyle=1;" edge="1" source="children_body" target="entry_body" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="40" y="125"/>
              <mxPoint x="40" y="700"/>
              <mxPoint x="460" y="700"/>
